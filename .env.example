# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — keep it that way.

# -----------------------------------------------------------------------------
# Newsletter subscribe — Microsoft 365 SMTP via nodemailer
# -----------------------------------------------------------------------------
# The send-as account must have SMTP AUTH enabled in the Microsoft 365 admin
# center:
#   Users → Active users → [the account] → Mail → Manage email apps →
#   check "Authenticated SMTP"
# If MFA is enforced on the mailbox, create an App Password and use it as
# SMTP_PASS (Security → Additional security verification → App passwords).

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=info@ai2innovate.io
SMTP_PASS=

# The inbox that receives new subscribers + the envelope sender address.
# Both default to info@ai2innovate.io. If they ever differ, make sure
# MAIL_FROM is allowed to send through SMTP_USER in your tenant.
MAIL_TO=info@ai2innovate.io
MAIL_FROM=info@ai2innovate.io
