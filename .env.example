# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — keep it that way.

# SendGrid API key with "Mail Send — Full Access" scope.
# Create at: https://app.sendgrid.com/settings/api_keys
# Starts with "SG." — never commit the real value.
SENDGRID_API_KEY=

# The sender must be verified in SendGrid (Single Sender Verification OR
# Domain Authentication for ai2innovate.io).
# Hard-coded to info@ai2innovate.io in src/app/api/subscribe/route.ts — edit
# that file if you change the inbox.
